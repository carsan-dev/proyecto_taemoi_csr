# Multi-stage build for production
FROM node:22-alpine AS build

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (including dev dependencies needed for build)
RUN npm ci && npm cache clean --force

# Copy source code
COPY . .

# Build for production
ARG ENVIRONMENT=production
RUN npm run build:production

# Production stage with Alpine nginx + Brotli support
FROM macbre/nginx-brotli:1.25.3-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

# Remove default nginx config
RUN rm /etc/nginx/nginx.conf
RUN rm /etc/nginx/conf.d/default.conf

# Copy built Angular app
COPY --from=build /app/dist/taemoi-angular-front/browser /usr/share/nginx/html

# Copy nginx configuration (will be overridden by volume mount in docker-compose)
COPY nginx.conf /etc/nginx/nginx.conf

# Create directories for Let's Encrypt
RUN mkdir -p /var/www/certbot

# Set proper permissions
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    chmod -R 755 /usr/share/nginx/html

# Expose ports
EXPOSE 80 443

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost/health || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
