# Production Environment Variables for TaeMoi Application
# Copy this file to .env.production and fill in your actual values

# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=taemoi_db
MYSQL_USER=taemoi_user
MYSQL_PASSWORD=your_secure_database_password_here

# Spring Boot Database Connection
SPRING_DATASOURCE_URL=jdbc:mysql://database:3306/taemoi_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=taemoi_user
SPRING_DATASOURCE_PASSWORD=your_secure_database_password_here

# JWT Secret (Generate a strong random string - minimum 256 bits)
# You can generate one with: openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_256_bits

# Email Configuration (Gmail SMTP)
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_specific_password
SPRING_MAIL_FROM=noreplymoiskimdo@gmail.com

# CORS Configuration
# Replace with your actual domain
CORS_ALLOWED_ORIGIN=https://your-domain.com,https://www.your-domain.com

# Application Base URL
# Replace with your actual domain
APP_BASE_URL=https://your-domain.com

# Domain Configuration (for SSL certificates)
DOMAIN=your-domain.com
EMAIL=admin@your-domain.com
